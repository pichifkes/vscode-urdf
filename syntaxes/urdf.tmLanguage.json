{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "URDF",
    "scopeName": "text.xml.urdf",
    "fileTypes": ["urdf", "xacro"],
    "patterns": [
        { "include": "#comment" },
        { "include": "#prolog" },
        { "include": "#tag" },
        { "include": "#xacro-interpolation" },
        { "include": "text.xml" }
    ],
    "repository": {
        "comment": {
            "begin": "<!--",
            "end": "-->",
            "name": "comment.block.xml",
            "captures": {
                "0": { "name": "punctuation.definition.comment.xml" }
            }
        },
        "prolog": {
            "begin": "(<\\?)(xml)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.tag.xml" },
                "2": { "name": "entity.name.tag.xml" }
            },
            "end": "(\\?>)",
            "endCaptures": {
                "1": { "name": "punctuation.definition.tag.xml" }
            },
            "name": "meta.tag.preprocessor.xml",
            "patterns": [
                { "include": "#attribute" }
            ]
        },
        "tag": {
            "begin": "(</?)([A-Za-z_:][\\w:.-]*)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.tag.xml" },
                "2": { "patterns": [{ "include": "#tag-name" }] }
            },
            "end": "(/?>)",
            "endCaptures": {
                "1": { "name": "punctuation.definition.tag.xml" }
            },
            "name": "meta.tag.xml",
            "patterns": [
                { "include": "#attribute" }
            ]
        },
        "tag-name": {
            "patterns": [
                { "match": "^xacro:[A-Za-z_][\\w_]*$", "name": "entity.name.function.xacro" },
                { "match": "^(robot|link|joint|transmission|gazebo)$", "name": "keyword.control.urdf" },
                { "match": "^(parent|child|mimic)$", "name": "variable.parameter.urdf" },
                { "match": "^(visual|collision|inertial|geometry|origin|axis|limit|dynamics|safety_controller|calibration)$", "name": "storage.type.urdf" },
                { "match": "^(material|color|texture)$", "name": "support.class.material.urdf" },
                { "match": "^(mass|inertia)$", "name": "support.function.inertial.urdf" },
                { "match": "^(box|cylinder|sphere|mesh)$", "name": "support.type.urdf" },
                { "match": "^(mu1|mu2|mu|kp|kd|maxVel|minDepth|maxContacts|selfCollide|turnGravityOff|gravity|implicitSpringDamper|dampingFactor|laserRetro|stopCfm|stopErp|fudgeFactor)$", "name": "support.constant.gazebo" },
                { "match": ".+", "name": "entity.name.tag.xml" }
            ]
        },
        "attribute": {
            "patterns": [
                {
                    "match": "([A-Za-z_:][\\w:.-]*)(=)",
                    "captures": {
                        "1": { "patterns": [{ "include": "#attribute-name" }] },
                        "2": { "name": "punctuation.separator.key-value.xml" }
                    }
                },
                { "include": "#string-double" },
                { "include": "#string-single" }
            ]
        },
        "attribute-name": {
            "patterns": [
                { "match": "^(name|link|joint|type|reference|rgba|xyz|rpy|size|radius|length|filename|scale|value|lower|upper|effort|velocity|damping|friction|multiplier|offset|ixx|ixy|ixz|iyy|iyz|izz|mass|x|y|z)$", "name": "entity.other.attribute-name.urdf" },
                { "match": ".+", "name": "entity.other.attribute-name.xml" }
            ]
        },
        "string-double": {
            "begin": "\"",
            "end": "\"",
            "name": "string.quoted.double.xml",
            "patterns": [
                { "include": "#xacro-interpolation" },
                { "include": "#joint-type-value" }
            ]
        },
        "string-single": {
            "begin": "'",
            "end": "'",
            "name": "string.quoted.single.xml",
            "patterns": [
                { "include": "#xacro-interpolation" },
                { "include": "#joint-type-value" }
            ]
        },
        "joint-type-value": {
            "match": "\\b(revolute|continuous|prismatic|fixed|floating|planar)\\b",
            "name": "constant.language.urdf"
        },
        "xacro-interpolation": {
            "name": "meta.interpolation.xacro",
            "match": "(\\$\\{)([^}]*)(\\})",
            "captures": {
                "1": { "name": "punctuation.definition.template-expression.begin" },
                "2": { "name": "variable.other.xacro" },
                "3": { "name": "punctuation.definition.template-expression.end" }
            }
        }
    }
}
