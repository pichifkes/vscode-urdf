{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "npm run build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$tsc", "$rustc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "build:server",
            "type": "shell",
            "command": "cargo build",
            "options": {
                "cwd": "${workspaceFolder}/server"
            },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "build:client",
            "type": "shell",
            "command": "npm run compile",
            "options": {
                "cwd": "${workspaceFolder}/client"
            },
            "problemMatcher": ["$tsc"]
        }
    ]
}
