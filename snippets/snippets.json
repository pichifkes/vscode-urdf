	"sensorLidar2D": {
		"prefix": ["lidar", "lidar2d", "laser", "sensor"],
		"body": [
			"<gazebo reference=\"${1:link_name}\">",
			"\t<sensor name=\"${2:lidar}\" type=\"ray\">",
			"\t\t<pose>0 0 0 0 0 0</pose>",
			"\t\t<visualize>true</visualize>",
			"\t\t<update_rate>${3:10.0}</update_rate>",
			"\t\t<ray>",
			"\t\t\t<scan>",
			"\t\t\t\t<horizontal>",
			"\t\t\t\t\t<samples>${4:360}</samples>",
			"\t\t\t\t\t<resolution>1</resolution>",
			"\t\t\t\t\t<min_angle>${5:-3.14159}</min_angle>",
			"\t\t\t\t\t<max_angle>${6:3.14159}</max_angle>",
			"\t\t\t\t</horizontal>",
			"\t\t\t</scan>",
			"\t\t\t<range>",
			"\t\t\t\t<min>${7:0.12}</min>",
			"\t\t\t\t<max>${8:3.5}</max>",
			"\t\t\t\t<resolution>${9:0.015}</resolution>",
			"\t\t\t</range>",
			"\t\t\t<noise>",
			"\t\t\t\t<type>gaussian</type>",
			"\t\t\t\t<mean>0.0</mean>",
			"\t\t\t\t<stddev>0.01</stddev>",
			"\t\t\t</noise>",
			"\t\t</ray>",
			"\t\t<plugin name=\"${10:lidar_controller}\" filename=\"libgazebo_ros_ray_sensor.so\">",
			"\t\t\t<ros>",
			"\t\t\t\t<namespace>${11:/}</namespace>",
			"\t\t\t\t<remapping>~/out:=${12:scan}</remapping>",
			"\t\t\t</ros>",
			"\t\t\t<output_type>sensor_msgs/LaserScan</output_type>",
			"\t\t\t<frame_name>${1:link_name}</frame_name>",
			"\t\t</plugin>",
			"\t</sensor>",
			"</gazebo>"
		],
		"description": "2D lidar / laser scanner (ray, LaserScan output)"
	},

	"sensorLidar3D": {
		"prefix": ["lidar3d", "velodyne", "pointcloud", "sensor"],
		"body": [
			"<gazebo reference=\"${1:link_name}\">",
			"\t<sensor name=\"${2:lidar3d}\" type=\"gpu_ray\">",
			"\t\t<pose>0 0 0 0 0 0</pose>",
			"\t\t<visualize>false</visualize>",
			"\t\t<update_rate>${3:10.0}</update_rate>",
			"\t\t<ray>",
			"\t\t\t<scan>",
			"\t\t\t\t<horizontal>",
			"\t\t\t\t\t<samples>${4:1024}</samples>",
			"\t\t\t\t\t<resolution>1</resolution>",
			"\t\t\t\t\t<min_angle>-3.14159</min_angle>",
			"\t\t\t\t\t<max_angle>3.14159</max_angle>",
			"\t\t\t\t</horizontal>",
			"\t\t\t\t<vertical>",
			"\t\t\t\t\t<samples>${5:16}</samples>",
			"\t\t\t\t\t<resolution>1</resolution>",
			"\t\t\t\t\t<min_angle>${6:-0.2617}</min_angle>",
			"\t\t\t\t\t<max_angle>${7:0.2617}</max_angle>",
			"\t\t\t\t</vertical>",
			"\t\t\t</scan>",
			"\t\t\t<range>",
			"\t\t\t\t<min>${8:0.9}</min>",
			"\t\t\t\t<max>${9:130.0}</max>",
			"\t\t\t\t<resolution>${10:0.001}</resolution>",
			"\t\t\t</range>",
			"\t\t</ray>",
			"\t\t<plugin name=\"${11:lidar3d_controller}\" filename=\"libgazebo_ros_ray_sensor.so\">",
			"\t\t\t<ros>",
			"\t\t\t\t<namespace>${12:/}</namespace>",
			"\t\t\t\t<remapping>~/out:=${13:points}</remapping>",
			"\t\t\t</ros>",
			"\t\t\t<output_type>sensor_msgs/PointCloud2</output_type>",
			"\t\t\t<frame_name>${1:link_name}</frame_name>",
			"\t\t</plugin>",
			"\t</sensor>",
			"</gazebo>"
		],
		"description": "3D lidar (gpu_ray, PointCloud2 output, Velodyne-style)"
	},

	"sensorImu": {
		"prefix": ["imu", "sensor"],
		"body": [
			"<gazebo reference=\"${1:link_name}\">",
			"\t<sensor name=\"${2:imu}\" type=\"imu\">",
			"\t\t<always_on>true</always_on>",
			"\t\t<update_rate>${3:100.0}</update_rate>",
			"\t\t<visualize>false</visualize>",
			"\t\t<imu>",
			"\t\t\t<angular_velocity>",
			"\t\t\t\t<x><noise type=\"gaussian\"><mean>0.0</mean><stddev>2e-4</stddev></noise></x>",
			"\t\t\t\t<y><noise type=\"gaussian\"><mean>0.0</mean><stddev>2e-4</stddev></noise></y>",
			"\t\t\t\t<z><noise type=\"gaussian\"><mean>0.0</mean><stddev>2e-4</stddev></noise></z>",
			"\t\t\t</angular_velocity>",
			"\t\t\t<linear_acceleration>",
			"\t\t\t\t<x><noise type=\"gaussian\"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></x>",
			"\t\t\t\t<y><noise type=\"gaussian\"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></y>",
			"\t\t\t\t<z><noise type=\"gaussian\"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></z>",
			"\t\t\t</linear_acceleration>",
			"\t\t</imu>",
			"\t\t<plugin name=\"${4:imu_controller}\" filename=\"libgazebo_ros_imu_sensor.so\">",
			"\t\t\t<ros>",
			"\t\t\t\t<namespace>${5:/}</namespace>",
			"\t\t\t\t<remapping>~/out:=${6:imu}</remapping>",
			"\t\t\t</ros>",
			"\t\t\t<initial_orientation_as_reference>false</initial_orientation_as_reference>",
			"\t\t\t<frame_name>${1:link_name}</frame_name>",
			"\t\t</plugin>",
			"\t</sensor>",
			"</gazebo>"
		],
		"description": "IMU sensor (angular velocity + linear acceleration)"
	},

	"sensorGps": {
