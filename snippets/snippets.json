	"sensorCamera": {
		"prefix": ["camera", "sensor"],
		"body": [
			"<gazebo reference=\"${1:link_name}\">",
			"\t<sensor name=\"${2:camera}\" type=\"camera\">",
			"\t\t<update_rate>${3:30.0}</update_rate>",
			"\t\t<visualize>true</visualize>",
			"\t\t<camera>",
			"\t\t\t<horizontal_fov>${4:1.396}</horizontal_fov>",
			"\t\t\t<image>",
			"\t\t\t\t<width>${5:640}</width>",
			"\t\t\t\t<height>${6:480}</height>",
			"\t\t\t\t<format>R8G8B8</format>",
			"\t\t\t</image>",
			"\t\t\t<clip>",
			"\t\t\t\t<near>${7:0.05}</near>",
			"\t\t\t\t<far>${8:8.0}</far>",
			"\t\t\t</clip>",
			"\t\t</camera>",
			"\t\t<plugin name=\"${9:camera_controller}\" filename=\"libgazebo_ros_camera.so\">",
			"\t\t\t<ros>",
			"\t\t\t\t<namespace>${10:/}</namespace>",
			"\t\t\t\t<remapping>image_raw:=${11:image_raw}</remapping>",
			"\t\t\t\t<remapping>camera_info:=${12:camera_info}</remapping>",
			"\t\t\t</ros>",
			"\t\t\t<camera_name>${2:camera}</camera_name>",
			"\t\t\t<frame_name>${1:link_name}</frame_name>",
			"\t\t</plugin>",
			"\t</sensor>",
			"</gazebo>"
		],
		"description": "Gazebo RGB camera sensor (gazebo_ros_camera)"
	},

