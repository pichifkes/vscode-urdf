	"linkFull": {
        "_comment": "Geometry primitive choice lists in <visual> and <collision> mirror GEOMETRY_PRIMITIVES in server/src/diagnostics.rs (single source of truth). Update both when adding a new URDF geometry primitive.",
        "prefix": "link",
        "body": [
            "<link name=\"${1:link_name}\">",
            "\t<inertial>",
            "\t\t<origin xyz=\"${2:0.0 0.0 0.0}\" rpy=\"${3:0.0 0.0 0.0}\"/>",
            "\t\t<mass value=\"${4:0.0}\"/>",
            "\t\t<inertia ixx=\"0.0\" ixy=\"0.0\" ixz=\"0.0\" iyy=\"0.0\" iyz=\"0.0\" izz=\"0.0\"/>",
            "\t</inertial>",
            "\t<visual name=\"\">",
            "\t\t<origin xyz=\"${5:0.0 0.0 0.0}\" rpy=\"${6:0.0 0.0 0.0}\"/>",
            "\t\t<geometry>",
            "\t\t\t${7|<box size=\"0.0 0.0 0.0\"/>,<cylinder radius=\"0.0\" length=\"0.0\"/>,<sphere radius=\"0.0\"/>,<mesh filename=\"\" scale=\"1.0 1.0 1.0\"/>|}",
            "\t\t</geometry>",
            "\t\t<material name=\"\">",
            "\t\t\t<color rgba=\"1.0 0.0 0.0 1.0\"/>",
            "\t\t\t<texture filename=\"\"/>",
            "\t\t</material>",
            "\t</visual>",
            "\t<collision>",
            "\t\t<origin xyz=\"${5:0.0 0.0 0.0}\" rpy=\"${6:0.0 0.0 0.0}\"/>",
            "\t\t<geometry>",
            "\t\t\t${7|<box size=\"0.0 0.0 0.0\"/>,<cylinder radius=\"0.0\" length=\"0.0\"/>,<sphere radius=\"0.0\"/>,<mesh filename=\"\" scale=\"1.0 1.0 1.0\"/>|}",
            "\t\t</geometry>",
            "\t</collision>",
            "</link>"
        ],
        "description": "Insert full link"
    },

